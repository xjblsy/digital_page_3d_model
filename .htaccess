NEW_FILE_CODE
# 为 GLB 和 GLTF 文件添加正确的 MIME 类型
<IfModule mod_mime.c>
    AddType model/gltf-binary .glb
    AddType model/gltf+json .gltf
</IfModule>

# 启用 CORS（如果需要）
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    <FilesMatch "\.(glb|gltf)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Cross-Origin-Resource-Policy "cross-origin"
    </FilesMatch>
</IfModule>
